  <Item class="Workspace" referent="167">
    <Properties>
      <string name="Name">Workspace</string>
      <bool name="NeedsPivotMigration">false</bool>
    </Properties>
    <Item class="Folder" referent="168">
      <Properties>
        <string name="Name">Art</string>
      </Properties>
      <Item class="Folder" referent="169">
        <Properties>
          <string name="Name">Plots</string>
        </Properties>
        <Item class="Model" referent="170">
          <Properties>
            <string name="Name">Model</string>
            <bool name="NeedsPivotMigration">false</bool>
          </Properties>
          <Item class="Folder" referent="171">
            <Properties>
              <string name="Name">Base</string>
            </Properties>
            <Item class="Folder" referent="172">
              <Properties>
                <string name="Name">Shops</string>
              </Properties>
              <Item class="Model" referent="173">
                <Properties>
                  <string name="Name">Shop</string>
                  <bool name="NeedsPivotMigration">false</bool>
