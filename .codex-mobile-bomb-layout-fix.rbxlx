-- =========================================================================
-- ## MAINTENANCE LOOP (Guarantees mines stay perfectly full) ##
-- =========================================================================
task.spawn(function()
	if not RunService:IsRunning() then return end
	while true do
		task.wait(10) -- Checks all mines every 10 seconds
		ItemManager.SpawnAllItems()
	end
end)

return ItemManager
