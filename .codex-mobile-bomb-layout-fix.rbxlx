	["SpinsX3"] = 3567801026,
	["SpinsX9"] = 3567801177,
}

ProductConfigurations.GamePasses = {
	["VIP"] = 1782060480,
	["StarterPack"] = 1781448453,
	["ProPack"] = 1780452467,
	["CollectAll"] = 1783037385,
}

ProductConfigurations.PackRewards = {
