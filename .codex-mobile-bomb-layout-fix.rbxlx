	[12] = { Id = 12, RequiredSeconds = 30 * 60, Type = "LuckyBlock", LuckyBlockId = "luckyblock_mythic", DisplayName = "Mythic Lucky Block", Image = "rbxassetid://79100659917134" } :: RewardEntry,
	
} :: { [number]: RewardEntry }

function PlaytimeRewardConfiguration.GetRewardById(rewardId: number): RewardEntry?
