	leftTabs.ScrollBarImageTransparency = 0.45
	leftTabs.Parent = body
	createCorner(leftTabs, 14)
	createStroke(leftTabs, THEME.stroke, 0.18, 1)

	local leftTabsContentFrame = Instance.new("Frame")
