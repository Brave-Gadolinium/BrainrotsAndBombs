      <Item class="ModuleScript" referent="28">
        <Properties>
          <string name="Name">Maid</string>
          <string name="Source">--!strict
-- A class for managing the cleanup of events and other objects.

local Maid = {}
Maid.__index = Maid

function Maid.new()
	local self = setmetatable({}, Maid)
	self._tasks = {}
	return self
end

function Maid:GiveTask(task: RBXScriptConnection | Instance | (() -> ()))
	if not task then
		return
	end

	local index = #self._tasks + 1
	self._tasks[index] = task
	return index
end

function Maid:DoCleaning()
	for _, task in ipairs(self._tasks) do
		if typeof(task) == "function" then
			task()
		elseif typeof(task) == "RBXScriptConnection" then
			task:Disconnect()
		elseif typeof(task) == "Instance" then
			task:Destroy()
		end
	end
	table.clear(self._tasks)
end

function Maid:Destroy()
	self:DoCleaning()
	table.clear(self)
end

return Maid</string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="29">
        <Properties>
          <string name="Name">MultiplierUtils</string>
          <string name="Source"><![CDATA[--!strict
-- LOCATION: ReplicatedStorage/Modules/MultiplierUtils

local MultiplierUtils = {}

function MultiplierUtils.GetRebirthMultiplier(rebirths: number?): number
	local resolvedRebirths = math.max(0, tonumber(rebirths) or 0)
	return 1 + (resolvedRebirths * 0.5)
end

function MultiplierUtils.FormatMultiplier(multiplier: number?): string
	local resolvedMultiplier = math.max(1, tonumber(multiplier) or 1)
	return string.format("x%.1f", resolvedMultiplier)
end

return MultiplierUtils
]]></string>
        </Properties>
      </Item>
