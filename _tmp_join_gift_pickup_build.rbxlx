		Damage = 10.5,
		Radius = 13,
		MaxDepthLevel = 5,
		Price = 50000000, -- было 94000000
		RobuxProductId = 3569248114,
		ImageId = "rbxassetid://123983988660865",
		ExplosionRadius = 13,
