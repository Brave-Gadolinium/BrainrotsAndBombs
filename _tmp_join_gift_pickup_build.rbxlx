}

function ContextualOfferConfiguration.GetDefinition(offerKey: string?): OfferDefinition?
	if type(offerKey) ~= "string" or offerKey == "" then
		return nil
	end

	return DEFINITIONS[offerKey]
end

return ContextualOfferConfiguration
