		task.wait(1)
		textObject:TweenPosition(UDim2.new(textObject.Position.X.Scale, textObject.Position.X.Offset, textObject.Position.Y.Scale + 0.02, textObject.Position.Y.Offset), "Out", "Sine", 1, true)
