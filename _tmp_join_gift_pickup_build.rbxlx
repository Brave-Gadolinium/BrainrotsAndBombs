          <string name="Source"><![CDATA[--!strict

return {
	UseCreatorGroup = true,
	ExplicitGroupId = nil,
	MinTesterRank = 200,
	MinAdminRank = 250,
	AllowedUsers = {
		[4349007560] = "admin",
		[8743799335] = "admin",
		[3905328439] = "admin",
		[62176368] = "admin",
		[9871888634] = "admin",
	},
	MaxAuditEntries = 100,
	HugeMoneyAmount = 1000000000,
}
]]></string>
